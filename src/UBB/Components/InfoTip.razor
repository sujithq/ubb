<span class="ubb-info-tip"
      data-bs-toggle="popover"
      data-bs-placement="@Placement"
      data-bs-html="true"
      data-bs-content="@PopoverContent"
      tabindex="0"
      role="note"
      aria-label="More information">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
    </svg>
</span>

@code {
    /// <summary>Plain-text explanation shown in the popover body.</summary>
    [Parameter] public string Text { get; set; } = "";

    /// <summary>Optional link to official GitHub docs. Appended as a "Docs ↗" link.</summary>
    [Parameter] public string? DocsUrl { get; set; }

    /// <summary>Bootstrap popover placement: top | bottom | left | right | auto.</summary>
    [Parameter] public string Placement { get; set; } = "top";

    private string PopoverContent =>
        string.IsNullOrEmpty(DocsUrl)
            ? Text
            : $"{Text} <a href='{DocsUrl}' target='_blank' rel='noopener noreferrer' class='ubb-tip-link'>Docs ↗</a>";
}
