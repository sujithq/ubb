@using UBB.Models
@using UBB.Services
@implements IDisposable

<div class="card card-ubb">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Multi-Cost-Center Scenarios</h5>
    </div>
    <div class="card-body">
        <!-- Preset Buttons -->
        <div class="mb-3">
            <label class="form-label fw-bold">Preset Scenarios:</label>
            <div class="d-grid gap-2">
                @foreach (var preset in ScenarioPresets.MultiCCPresets)
                {
                    var isActive = preset.Key == _activePresetKey;
                    <button type="button" class="btn @(isActive ? "btn-info" : "btn-outline-info") text-start" 
                            @onclick="() => SelectPreset(preset)">
                        <div class="fw-bold">@(isActive ? "✓ " : "")@preset.Label</div>
                        <div class="small @(isActive ? "text-white" : "text-muted")">@preset.Description</div>
                    </button>
                }
            </div>
        </div>

        <hr />

        <!-- Manual Configuration -->
        <div class="mb-3">
            <label class="form-label fw-bold">Or Configure Manually:</label>

            @if (CurrentState != null)
            {
                <!-- Global Budgets -->
                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <h6 class="card-title">Organization Budgets & Request Size</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold" for="pool-input">Shared Pool Remaining</label>
                                <input id="pool-input" type="number" class="form-control form-control-sm" min="0" step="1000"
                                       value="@CurrentState.PoolRemainingCredits"
                                       @onchange="e => UpdatePool(e)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold" for="ent-input">Enterprise Metered Cap</label>
                                <input id="ent-input" type="number" class="form-control form-control-sm" min="0" step="1000"
                                       value="@CurrentState.EnterpriseMeteredRemainingCredits"
                                       @onchange="e => UpdateEnterprise(e)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold" for="req-input">Request per CC (credits)</label>
                                <input id="req-input" type="number" class="form-control form-control-sm" min="100" step="100"
                                       value="@CurrentState.RequestCreditsPerCC"
                                       @onchange="e => UpdateRequestCredits(e)" />
                                <div class="form-text small">Per cost center</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cost Centers Editor -->
                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="card-title mb-0">Cost Centers</h6>
                            <button type="button" class="btn btn-sm btn-success" @onclick="AddCostCenter">+ Add</button>
                        </div>

                        @foreach (var (cc, idx) in CurrentState.CostCenters.Select((c, i) => (c, i)))
                        {
                            <div class="input-group input-group-sm mb-2">
                                <input type="text" class="form-control" placeholder="CC Name" 
                                       value="@cc.Name"
                                       @onchange="e => UpdateCCName(idx, e)" />
                                <input type="number" class="form-control" style="max-width: 100px;" placeholder="Users" min="1" 
                                       value="@cc.UserCount"
                                       @onchange="e => UpdateCCUserCount(idx, e)" />
                                <input type="number" class="form-control" style="max-width: 150px;" placeholder="Metered Budget" min="0" step="1000"
                                       value="@cc.MeteredRemainingCredits"
                                       @onchange="e => UpdateCCBudget(idx, e)" />
                                <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveCostCenter(idx)">✕</button>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted small">Select a preset first to enable manual configuration.</p>
            }
        </div>

        <hr />

        <!-- Run button -->
        @if (CurrentState?.CostCenters.Count > 0)
        {
            <div class="mb-3">
                <button type="button" class="btn btn-success w-100" @onclick="RunSimulation">
                    ▶ Run Multi-CC Simulation
                </button>
            </div>

            <!-- Org-level status cards -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="card bg-light">
                        <div class="card-body py-2">
                            <div class="small text-muted">Shared Pool remaining</div>
                            <div class="h5 mb-0 text-primary">@CurrentState.PoolRemainingCredits.ToString("N0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card bg-light">
                        <div class="card-body py-2">
                            <div class="small text-muted">Enterprise Cap remaining</div>
                            <div class="h5 mb-0 text-info">@CurrentState.EnterpriseMeteredRemainingCredits.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Per-CC flow diagrams (shown after simulation) -->
            @if (CurrentState.Logs.Count > 0)
            {
                @if (_activePresetKey != null)
                {
                    var activePreset = ScenarioPresets.MultiCCPresets.FirstOrDefault(p => p.Key == _activePresetKey);
                    @if (activePreset != null)
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <span class="fw-semibold">Preset:</span> @activePreset.Label
                            <span class="text-muted ms-2 small">— @activePreset.Description</span>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-secondary py-2 mb-3">
                        <span class="fw-semibold">Manual configuration</span>
                    </div>
                }
                <div class="mb-3">
                    <h6 class="fw-bold">Cost Center Flow Diagrams</h6>
                    @foreach (var cc in CurrentState.CostCenters)
                    {
                        <MultiCCFlowDiagram Cc="cc" />
                    }
                </div>

                <div class="card bg-dark text-light">
                    <div class="card-header">
                        <h6 class="mb-0">Simulation Log</h6>
                    </div>
                    <div class="card-body" style="max-height: 300px; overflow-y: auto; font-family: monospace; font-size: 0.875rem;">
                        @foreach (var log in CurrentState.Logs)
                        {
                            <div>@log</div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted text-center">Select a preset or configure manually to begin.</p>
        }
    </div>
</div>

@code {
    [Inject] private AppStateService AppStateService { get; set; } = default!;

    private MultiCostCenterState? CurrentState;
    private string? _activePresetKey;

    protected override void OnInitialized()
    {
        AppStateService.OnChange += OnAppStateChanged;
        // Pick up any state restored from a shared URL before first render
        SyncFromAppState();
    }

    public void Dispose() => AppStateService.OnChange -= OnAppStateChanged;

    private void OnAppStateChanged()
    {
        SyncFromAppState();
        StateHasChanged();
    }

    private void SyncFromAppState()
    {
        // If AppState holds a MultiCCState (e.g. restored from URL) that we haven't seen yet, adopt it.
        if (AppStateService.MultiCCState != null && AppStateService.MultiCCState != CurrentState)
        {
            CurrentState = AppStateService.MultiCCState;
            // Sync the active preset key only when it belongs to a multi-CC preset
            if (AppStateService.ActivePresetKey != null &&
                ScenarioPresets.MultiCCPresets.Any(p => p.Key == AppStateService.ActivePresetKey))
            {
                _activePresetKey = AppStateService.ActivePresetKey;
            }
        }
    }

    private void SelectPreset(MultiCCPreset preset)
    {
        CurrentState = MultiCostCenterState.CreateDefault();
        preset.ApplyTo(CurrentState);
        _activePresetKey = preset.Key;
        AppStateService.SetMultiCCState(CurrentState, preset.Key);
    }

    private void UpdatePool(ChangeEventArgs e)
    {
        if (CurrentState == null) return;
        if (int.TryParse(e.Value?.ToString() ?? "0", out var v))
            CurrentState.PoolRemainingCredits = v;
        _activePresetKey = null;
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void UpdateEnterprise(ChangeEventArgs e)
    {
        if (CurrentState == null) return;
        if (int.TryParse(e.Value?.ToString() ?? "0", out var v))
            CurrentState.EnterpriseMeteredRemainingCredits = v;
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void UpdateRequestCredits(ChangeEventArgs e)
    {
        if (CurrentState == null) return;
        if (int.TryParse(e.Value?.ToString() ?? "2000", out var v))
            CurrentState.RequestCreditsPerCC = v;
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void UpdateCCName(int idx, ChangeEventArgs e)
    {
        if (CurrentState == null || idx < 0 || idx >= CurrentState.CostCenters.Count) return;
        CurrentState.CostCenters[idx].Name = e.Value?.ToString() ?? "";
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void UpdateCCUserCount(int idx, ChangeEventArgs e)
    {
        if (CurrentState == null || idx < 0 || idx >= CurrentState.CostCenters.Count) return;
        if (int.TryParse(e.Value?.ToString() ?? "1", out var v))
            CurrentState.CostCenters[idx].UserCount = v;
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void UpdateCCBudget(int idx, ChangeEventArgs e)
    {
        if (CurrentState == null || idx < 0 || idx >= CurrentState.CostCenters.Count) return;
        if (int.TryParse(e.Value?.ToString() ?? "0", out var v))
        {
            CurrentState.CostCenters[idx].MeteredRemainingCredits = v;
            CurrentState.CostCenters[idx].InitialMeteredBudget    = v;
        }
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void AddCostCenter()
    {
        if (CurrentState == null) return;
        CurrentState.CostCenters.Add(new CostCenterBudget
        {
            Name                    = $"New CC {CurrentState.CostCenters.Count + 1}",
            UserCount               = 1,
            MeteredRemainingCredits = 100_000,
            InitialMeteredBudget    = 100_000,
        });
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void RemoveCostCenter(int index)
    {
        if (CurrentState == null || index < 0 || index >= CurrentState.CostCenters.Count) return;
        CurrentState.CostCenters.RemoveAt(index);
        AppStateService.SetMultiCCState(CurrentState);
    }

    private void RunSimulation()
    {
        if (CurrentState == null) return;
        AppStateService.RunMultiCostCenter(CurrentState);
        StateHasChanged();
    }
}
